# Custom Terminal Shortcuts

# Git
alias ccc="git add . && git commit -m 'quick commit' && git push"
alias gstatus="git status"
alias gl="git log --oneline --graph --decorate -20"
alias gd="git diff"
alias gco="git checkout"

# Navigation / misc
alias ll="ls -alh"
alias ..="cd .."
alias ...="cd ../.."
